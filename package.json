{
  "name": "playwright-auto-test-generation-project",
  "version": "1.0.0",
  "description": "Production-ready autonomous E2E testing framework with Playwright, TypeScript, and AI capabilities",
  "type": "module",
  "scripts": {
    "install:playwright": "playwright install --with-deps",
    "init:agents": "npx playwright init-agents --loop=vscode",
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:ui": "playwright test --ui",
    "test:report": "playwright show-report",
    "test:chromium": "playwright test --project=chromium",
    "test:firefox": "playwright test --project=firefox",
    "test:webkit": "playwright test --project=webkit",
    "agent:plan": "npx playwright test-agent --mode=plan",
    "agent:generate": "npx playwright test-agent --mode=generate",
    "agent:heal": "npx playwright test-agent --mode=heal",
    "agent:autonomous": "npx playwright test-agent --mode=autonomous",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"**/*.{ts,js,json,md}\"",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "playwright",
    "e2e",
    "testing",
    "automation",
    "typescript",
    "ai",
    "autonomous",
    "self-healing"
  ],
  "author": "QA Automation Team",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-playwright": "^1.6.0",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
